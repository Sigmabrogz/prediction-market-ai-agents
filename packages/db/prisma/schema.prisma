generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  createdAt     DateTime       @default(now())
  wallets       UserWallet[]
  subscriptions Subscription[]
}

model UserWallet {
  id         String @id @default(uuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id])
  address    String @unique
  privateKey String 
  balance    Float  @default(0)
}

model SniperPool {
  id               String         @id @default(uuid())
  marketId         String         @unique
  title            String
  resolutionSource String
  status           String         @default("ACTIVE")
  subscriptions    Subscription[]
}

model Subscription {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  poolId       String
  pool         SniperPool @relation(fields: [poolId], references: [id])
  maxTradeSize Float
  active       Boolean    @default(true)
}

model Strategy {
  id        String       @id @default(uuid())
  name      String
  type      String
  config    String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  signals   Signal[]
  orders    Order[]
  positions Position[]
}

model Signal {
  id               String    @id
  signalId         String
  strategyId       String
  strategy         Strategy  @relation(fields: [strategyId], references: [id])
  oracleSource     String
  marketId         String
  marketSlug       String?
  triggerType      String
  triggerPayload   String
  emittedAt        DateTime
  receivedAt       DateTime  @default(now())
  mode             String
  createdAt        DateTime  @default(now())

  orders           Order[]

  @@index([signalId])
  @@index([strategyId])
  @@index([marketId])
  @@index([createdAt])
}

model Order {
  id              String      @id @default(uuid())
  externalOrderId String?     @unique
  signalId        String?
  signal          Signal?     @relation(fields: [signalId], references: [id])
  strategyId      String
  strategy        Strategy    @relation(fields: [strategyId], references: [id])
  marketId        String
  mode            String
  side            String
  orderType       String      // e.g., "LIMIT", "MARKET"
  limitPrice      Float
  requestedSize   Float
  submittedSize   Float?
  status          String      @default("SIGNAL_RECEIVED")
  submittedAt     DateTime?
  lastStatusAt    DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  fills           Fill[]
  lifecycle       OrderLifecycleEvent[]

  @@index([signalId])
  @@index([strategyId])
  @@index([marketId])
  @@index([status])
  @@index([mode])
  @@index([createdAt])
}

model OrderLifecycleEvent {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  status    String
  payload   String?
  timestamp DateTime    @default(now())

  @@index([orderId])
  @@index([timestamp])
}

model Fill {
  id            String    @id @default(uuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id])
  fillPrice     Float
  fillSize      Float
  fee           Float?
  liquidityType String?   // "MAKER" | "TAKER"
  filledAt      DateTime  @default(now())

  @@index([orderId])
}

model Position {
  id            String    @id @default(uuid())
  marketId      String
  strategyId    String
  strategy      Strategy  @relation(fields: [strategyId], references: [id])
  mode          String
  side          String    // e.g., "YES" or "NO"
  quantity      Float
  avgEntryPrice Float
  realizedPnl   Float     @default(0.0)
  unrealizedPnl Float?
  status        String    // "OPEN" | "CLOSED" | "RESOLVED"
  openedAt      DateTime  @default(now())
  closedAt      DateTime?
  updatedAt     DateTime  @updatedAt

  @@index([marketId])
  @@index([strategyId])
  @@index([mode])
  @@index([status])
}

model PnlSnapshot {
  id            String    @id @default(uuid())
  strategyId    String?
  mode          String
  realizedPnl   Float
  unrealizedPnl Float
  timestamp     DateTime  @default(now())

  @@index([strategyId])
  @@index([mode])
  @@index([timestamp])
}

model SystemEvent {
  id        String              @id @default(uuid())
  component String
  eventType String
  severity  String              @default("INFO")
  payload   String?
  timestamp DateTime            @default(now())

  @@index([component])
  @@index([severity])
  @@index([timestamp])
}
